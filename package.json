{
  "name": "ccusageview",
  "version": "0.1.0",
  "bin": {
    "ccusageview": "dist-cli/ccusageview.mjs"
  },
  "files": [
    "dist-cli"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:cli": "esbuild src/cli/main.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist-cli/ccusageview.mjs --banner:js='#!/usr/bin/env node'",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "pricing:update": "bash ./scripts/update_offline_pricing.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "cf:dev": "pnpm build && wrangler dev",
    "cf:upload": "pnpm build && wrangler versions upload",
    "cf:deploy": "pnpm build && wrangler deploy",
    "prepublishOnly": "pnpm build:cli"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "hono": "^4.11.9",
    "nanoid": "^5.1.6",
    "react-chartjs-2": "^5.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "esbuild": "0.28.1",
    "html-to-image": "1.11.13",
    "lefthook": "2.1.10",
    "lz-string": "1.5.0",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.2",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.11.0"
}
